# VCS & meta
.git
.github
.DS_Store

# Build artifacts
**/target
**/dist
**/build
**/.eggs
**/*.egg-info

# Node & Python caches
**/node_modules
**/__pycache__
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.venv
**/.gocache
**/.gomodcache

# Local secrets
secrets/

# Local Go binaries
go/orchestrator/gateway
go/orchestrator/orchestrator
go/orchestrator/replay

# Test fixtures and generated assets
tests/fixtures/mock_responses/
protos/gen/
# Generated Go protobuf files — regenerated by `buf generate` inside the Go
# image builds. Excluding them prevents a stale dev-tree copy from clobbering
# the freshly generated ones during `COPY` (would drop newer proto fields).
# Python grpc_gen *_pb2.py are committed and intentionally NOT matched here.
**/*.pb.go

# Local env & secrets (use .env.example)
.env
.env.*
!*.env.example

# Docs (exclude from image contexts unless explicitly copied)
docs/

# Logs
**/*.log
**/logs/
